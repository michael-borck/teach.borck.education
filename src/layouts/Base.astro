---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'teach.borck.dev',
  description = 'Workshops, courses, and executive education by Michael Borck.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" />
</head>
<body>
  <slot />
</body>
</html>
