---
import Base from '../layouts/Base.astro';
import { teaching, categories } from '../data/teaching.ts';

const teachingData = teaching;
---
<Base title="teach.borck.education" description="Workshops, courses, and executive education by Michael Borck.">

<div class="topbar">
  <a class="topbar-logo" href="/">teach<span class="dot">.</span>borck<span class="dot">.</span><span class="sub">education</span></a>
  <div class="topbar-search">
    <input id="search-input" type="search" placeholder="Search sessions…" />
  </div>
  <div class="topbar-filter">
    <label for="cat-filter">Category</label>
    <select id="cat-filter">
      {categories.map(c => <option value={c.value}>{c.label}</option>)}
    </select>
  </div>
  <div class="topbar-spacer"></div>
  <nav class="topbar-links">
    <a href="https://borck.education" title="Tools, books, and teaching for educators and students">Education</a>
    <a href="https://borck.consulting" title="AI strategy and education consulting">Consulting</a>
    <a href="https://research.borck.dev" title="Academic research, papers, and HCI work">Research</a>
    <a href="https://resume.borck.dev" title="CV in 10 formats from a single YAML data source">Resume</a>
    <a href="https://borck.dev" title="Builder, educator, researcher, and consultant">borck.dev</a>
  </nav>
</div>

<main class="main" id="main">

  <!-- Home view -->
  <div class="home-view" id="home-view">
    <div class="home-hero">
      <p class="home-eyebrow">teach.borck.education</p>
      <h1 class="home-title">Workshops, courses &amp;<br><span class="home-accent">executive education</span></h1>
      <p class="home-sub">AI literacy, curriculum design, and leadership programmes — from undergraduate courses to boardroom masterclasses.</p>
      <div class="home-cats">
        {categories.filter(c => c.value !== 'all').map(c => (
          <button class="home-cat-btn" data-cat={c.value}>{c.label}</button>
        ))}
      </div>
      <button class="home-browse-btn" id="browse-btn">
        Browse all {teachingData.length} sessions →
      </button>
      <div class="home-trust">
        <span class="home-trust-item">Faculty &amp; Staff Development</span>
        <span class="home-trust-item">·</span>
        <span class="home-trust-item">Industry &amp; Executive</span>
      </div>
    </div>
  </div>

  <!-- Grid view -->
  <div class="grid-view hidden" id="grid-view">
    <div class="grid-header">
      <span class="grid-title" id="grid-label">All sessions</span>
      <span class="grid-count" id="grid-count"></span>
    </div>
    <div class="teach-grid" id="teach-grid">
      {teachingData.map(t => (
        <a class="grid-card" data-teach={t.id} href="#" data-cat={t.category}>
          <div class="grid-card-name">{t.name}</div>
          <div class="grid-card-desc">{t.description}</div>
          <div class="grid-card-footer">
            <span class="cat-badge">{t.category === 'exec-ed' ? 'Exec Ed' : t.category.charAt(0).toUpperCase() + t.category.slice(1)}</span>
            <span class="format-badge">{t.format}</span>
          </div>
        </a>
      ))}
      <div class="no-results hidden" id="no-results">No sessions match your search.</div>
    </div>
  </div>

  <!-- Detail view -->
  <div class="detail-view hidden" id="detail-view">
    <div class="detail-back-bar">
      <button class="back-btn" id="back-btn">← Back</button>
    </div>
    <div id="detail-content"></div>
  </div>

</main>

<footer class="site-footer">
  <div class="footer-links">
    <a href="https://borck.education">Education</a>
    <a href="https://borck.consulting">Consulting</a>
    <a href="https://research.borck.dev">Research</a>
    <a href="https://resume.borck.dev">Resume</a>
    <a href="https://borck.dev">borck.dev</a>
    <a href="https://linkedin.com/in/michaelborck">LinkedIn</a>
  </div>
  <p>Michael Borck · Perth, WA</p>
</footer>

<script define:vars={{ teachingData }}>
let activeId = null;
let currentView = 'home';

function showHome() {
  currentView = 'home';
  document.getElementById('home-view').classList.remove('hidden');
  document.getElementById('grid-view').classList.add('hidden');
  document.getElementById('detail-view').classList.add('hidden');
}

function showGrid() {
  currentView = 'grid';
  document.getElementById('home-view').classList.add('hidden');
  document.getElementById('grid-view').classList.remove('hidden');
  document.getElementById('detail-view').classList.add('hidden');
  applyFilters();
}

function showDetail() {
  document.getElementById('home-view').classList.add('hidden');
  document.getElementById('grid-view').classList.add('hidden');
  document.getElementById('detail-view').classList.remove('hidden');
}

function openTeach(id) {
  activeId = id;
  const t = teachingData.find(x => x.id === id);
  if (!t) return;

  const catLabel = {
    university: 'University',
    workshop: 'Workshop',
    'exec-ed': 'Executive Education',
    research: 'Research'
  }[t.category] || t.category;

  document.getElementById('detail-content').innerHTML = `
    <div class="teach-panel">
      <div class="panel-left">
        <div class="panel-name">${t.name}</div>
        <div class="panel-meta">
          <span class="cat-badge">${catLabel}</span>
          <span class="format-badge">${t.format}</span>
        </div>
        <p class="panel-desc">${t.description}</p>
        <div class="panel-detail-label">Audience</div>
        <div class="panel-detail-value">${t.audience}</div>
        <a class="panel-cta" href="${t.siteUrl}" target="_blank">View materials →</a>
        <div class="panel-repo-link"><a href="${t.repoUrl}" target="_blank">GitHub repo ↗</a></div>
      </div>
      <div class="panel-right">
        <div class="panel-detail-label">Tags</div>
        <div class="panel-detail-value">${t.tags.map(tag => `<span class="cat-badge" style="margin-right:0.3rem">${tag}</span>`).join('')}</div>
        <div class="panel-detail-label" style="margin-top:1rem">Format</div>
        <div class="panel-detail-value">${t.format}</div>
      </div>
    </div>
  `;

  showDetail();
}

function applyFilters() {
  const search = document.getElementById('search-input').value.toLowerCase();
  const cat = document.getElementById('cat-filter').value;
  const cards = document.querySelectorAll('.grid-card');
  let visible = 0;

  cards.forEach(card => {
    const id = card.dataset.teach;
    const t = teachingData.find(x => x.id === id);
    if (!t) return;
    const matchCat = cat === 'all' || t.category === cat;
    const matchSearch = !search || t.name.toLowerCase().includes(search) || t.description.toLowerCase().includes(search) || t.tags.some(tag => tag.toLowerCase().includes(search));
    const show = matchCat && matchSearch;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });

  document.getElementById('no-results').classList.toggle('hidden', visible > 0);
  document.getElementById('grid-count').textContent = visible + ' session' + (visible !== 1 ? 's' : '');

  const catLabel = cat === 'all' ? 'All sessions' : {
    university: 'University courses',
    workshop: 'Workshops',
    'exec-ed': 'Executive Education',
    research: 'Research'
  }[cat] || cat;
  document.getElementById('grid-label').textContent = catLabel;
}

// Events
document.getElementById('browse-btn').addEventListener('click', showGrid);
document.getElementById('back-btn').addEventListener('click', () => {
  activeId ? showGrid() : showHome();
  activeId = null;
});

document.querySelectorAll('.home-cat-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('cat-filter').value = btn.dataset.cat;
    showGrid();
  });
});

document.getElementById('search-input').addEventListener('input', () => {
  if (currentView !== 'grid') showGrid();
  else applyFilters();
});
document.getElementById('cat-filter').addEventListener('change', () => {
  if (currentView !== 'grid') showGrid();
  else applyFilters();
});

document.addEventListener('click', e => {
  const el = e.target.closest('[data-teach]');
  if (!el) return;
  e.preventDefault();
  openTeach(el.dataset.teach);
});
</script>

</Base>
